# Copy this to server/.env for local dev
# On Railway, set these in the Variables tab

PORT=3001
NODE_ENV=production

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Railway volume mount path (set to /data/blabberbox.db on Railway)
DB_PATH=/data/blabberbox.db

# Allow all origins in production (Railway handles SSL)
CLIENT_URL=*

BCRYPT_ROUNDS=12
